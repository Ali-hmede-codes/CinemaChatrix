# ===== Server =====
PORT=3001
NODE_ENV=development

# ===== Database =====
DB_PATH=./database/cinema.db

# ===== JWT =====
JWT_SECRET=your-super-secret-key-change-this-to-random-64-chars
JWT_EXPIRES_IN=24h

# ===== Admin =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# ===== Upload =====
MAX_UPLOAD_SIZE=5GB
UPLOAD_DIR=./uploads
TEMP_DIR=./uploads/_temp

# ===== Compression =====
# FFmpeg/ffprobe are bundled via the ffmpeg-static / ffprobe-static packages and
# resolved automatically — no system install needed. Uncomment and set these
# only to override with a system-wide FFmpeg (absolute path or command name).
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe
VIDEO_CRF=23
# Encoder speed preset (only used when a real re-encode is needed). Faster =
# quicker imports, slightly larger files. veryfast is a good balance.
VIDEO_PRESET=veryfast
# Video encoder. 'auto' prefers hardware (NVENC/QSV/AMF) and falls back to
# libx264. Force a specific one if you prefer (libx264, h264_nvenc, ...).
# Sources already in H.264 within MAX_RESOLUTION are stream-copied (no
# re-encode) regardless of this setting, which makes most imports near-instant.
VIDEO_ENCODER=auto
MAX_RESOLUTION=1080

# ===== Download (remote import) =====
# Remote imports open MANY parallel connections to a link (fed by a work-queue)
# so one throttled connection can't cap the whole transfer (like IDM/aria2c) and
# your full line speed is used. Only applies when the source supports HTTP range
# requests; otherwise it falls back to a single stream. Set DOWNLOAD_CONNECTIONS=1
# to disable parallel downloading. More connections = more speed against a
# per-connection-throttling host; raise toward 32 if your line is faster.
DOWNLOAD_CONNECTIONS=8
# Only parallelize files larger than this many MB; smaller ones use 1 connection.
DOWNLOAD_PARALLEL_MIN_MB=16
# Work-queue segment size (MB). Smaller = better load-balancing across
# connections (avoids one slow chunk stalling the tail); 8 is a good default.
DOWNLOAD_CHUNK_MB=8
# Abort a download connection if it stalls this long (milliseconds).
DOWNLOAD_TIMEOUT_MS=300000

# ===== Security =====
CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
CODE_RATE_LIMIT_MAX=5

# ===== Player =====
PLYR_VERSION=3.7.8
