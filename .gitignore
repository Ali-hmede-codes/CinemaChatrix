# ─────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────
node_modules/
**/node_modules/
.npm/
.pnp/
.pnp.js

# ─────────────────────────────────────────────
# Environment / secrets
# ─────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/logs/*
!backend/logs/.gitkeep

# ─────────────────────────────────────────────
# Database (SQLite)
# ─────────────────────────────────────────────
backend/database/*.db
backend/database/*.db-journal
backend/database/*.db-wal
backend/database/*.db-shm
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────
# Uploads — never commit video files
# ─────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep
!backend/uploads/_temp/
backend/uploads/_temp/*
!backend/uploads/_temp/.gitkeep

# ─────────────────────────────────────────────
# Generated media (posters / thumbnails)
# ─────────────────────────────────────────────
backend/public/posters/*
!backend/public/posters/.gitkeep
backend/public/thumbnails/*
!backend/public/thumbnails/.gitkeep

# ─────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ─────────────────────────────────────────────
# Editor / IDE
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# Build / coverage / temp
# ─────────────────────────────────────────────
dist/
build/
coverage/
tmp/
*.tmp
